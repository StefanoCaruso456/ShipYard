PORT=8787
# Vercel should set this to the Railway server origin in production.
VITE_API_URL=http://localhost:8787
# Server-side model execution. Set this on the runtime host.
OPENAI_KEY=
# Optional compatibility fallback for providers that expect the standard OpenAI env name.
OPENAI_API_KEY=
# Optional model override for the Vercel AI SDK OpenAI executor.
OPENAI_MODEL=gpt-4o-mini
# Optional model override for server-side audio transcription used by the mic flow.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=shipyard-runtime-observability
LANGSMITH_TRACING=true
# Preferred LangSmith workspace selector for this runtime.
WORKSPACE_ID=
# Backwards-compatible fallback if WORKSPACE_ID is not set.
LANGSMITH_WORKSPACE_ID=
