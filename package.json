{
  "name": "shipyard",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @shipyard/server dev\" \"pnpm --filter @shipyard/client dev\"",
    "build": "pnpm -r build",
    "start": "node apps/server/dist/index.js",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^6.0.2"
  }
}
